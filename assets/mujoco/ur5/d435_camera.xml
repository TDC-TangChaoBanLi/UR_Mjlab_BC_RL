<!--
  RealSense D435 手眼相机 MJCF
  挂载在夹爪侧面，用于腕部 RGBD 观测
-->
<mujoco model="d435_camera">
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>

  <default>
    <default class="camera">
      <default class="visual">
        <geom contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom contype="1" conaffinity="1" group="3"/>
      </default>
    </default>
  </default>

  <asset>
    <!-- D435 meshes -->
    <mesh name="MESH_d435_6743a526_0"  file="d435_6743a526_0.obj"/>
