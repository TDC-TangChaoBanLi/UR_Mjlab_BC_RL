      <body name="realsense_link" pos="0.0106 0.0175 0.0125" quat="1 0 0 0">
        <inertial mass="0.072" diaginertia="0.003881243 0.00049894 0.003879257" pos="0 0 0" quat="1 0 0 0"/>
        <geom class="collision" name="COLLISION_realsense_link_0" type="box" pos="0 -0.0175 0" quat="1 0 0 0" size="0.012525 0.045 0.0125"/>

        <!-- D435 visual meshes -->
        <geom class="visual" name="VISUAL_realsense_link_0"  type="mesh" mesh="MESH_d435_6743a526_0"  rgba="0.749 0.749 0.749 1" pos="0.0043 -0.0175 0" quat="0.5 0.5 0.5 0.5"/>
